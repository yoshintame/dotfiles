config := env('HOME') + "/.config/resticprofile"
apprise := config + "/apprise.yaml"

default:
    just -f {{ justfile_directory() + "/justfile" }} --list

# Run backup: [all|dev|home|...]
backup profile="all":
    resticprofile -n {{profile}} backup

# Copy local repo → B2
push:
    resticprofile -n local-to-b2 copy

# Full cycle: backup all + copy to B2
backup-and-push:
    resticprofile -n all backup
    resticprofile -n local-to-b2 copy

# List snapshots: [local|b2] [all|dev|home]
snapshots repo="local" tag="":
    #!/usr/bin/env sh
    case "{{tag}}" in
        "") resticprofile -n {{repo}} snapshots ;;
        *)  resticprofile -n {{repo}} snapshots --tag {{tag}} ;;
    esac

# Repo stats: [dev|home|b2]
stats profile="dev":
    #!/usr/bin/env sh
    if [ "{{profile}}" = "b2" ]; then
        resticprofile -n b2-ops stats
    else
        resticprofile -n {{profile}} stats
    fi

# Forget + prune: [all|local|b2]
maintenance target="all":
    #!/usr/bin/env sh
    case "{{target}}" in
        all)   resticprofile -n maintenance forget ;;
        local) resticprofile -n local-ops forget ;;
        b2)    resticprofile -n b2-ops forget ;;
        *)     echo "Unknown target: {{target}}. Use: all, local, b2" && exit 1 ;;
    esac

# Integrity check: [all|local|b2|full] (full = read all data, slow)
check target="all":
    #!/usr/bin/env sh
    case "{{target}}" in
        all)   resticprofile -n check check ;;
        local) resticprofile -n local-ops check ;;
        b2)    resticprofile -n b2-ops check ;;
        full)  resticprofile -n local-ops check --read-data ;;
        *)     echo "Unknown target: {{target}}. Use: all, local, b2, full" && exit 1 ;;
    esac

# Manage cron schedules: [up|down|reload|status]
schedule action="status":
    #!/usr/bin/env sh
    LOGROTATE_LINE="0 7 * * * /opt/homebrew/sbin/logrotate --state $HOME/.local/share/resticprofile/logrotate.state $HOME/.config/resticprofile/logrotate.conf # logrotate-resticprofile"
    _cron_add_logrotate() {
        (crontab -l 2>/dev/null | grep -v "logrotate-resticprofile"; echo "$LOGROTATE_LINE") | crontab -
    }
    _cron_remove_logrotate() {
        (crontab -l 2>/dev/null | grep -v "logrotate-resticprofile") | crontab -
    }
    case "{{action}}" in
        up)
            _cron_add_logrotate
            resticprofile schedule --all
            ;;
        down)
            resticprofile unschedule --all
            _cron_remove_logrotate
            ;;
        reload)
            resticprofile unschedule --all
            _cron_add_logrotate
            resticprofile schedule --all
            resticprofile status
            ;;
        status) resticprofile status --all ;;
        *)      echo "Unknown action: {{action}}. Use: up, down, reload, status" && exit 1 ;;
    esac

# --- Quick save/load (full, no exclusions) ---

# Save current dir (full backup, no exclusions): <dir>
save dir:
    RP_SAVE_DIR={{dir}} resticprofile -n quicksave backup

# Load current dir from latest snapshot: <dir> [clean=true]
load dir clean="true":
    #!/usr/bin/env sh
    if [ "{{clean}}" = "true" ]; then
        find "{{dir}}" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
    fi
    resticprofile -n quicksave restore "latest:{{dir}}" --target "{{dir}}"

# --- Restore ---

# Restore file/dir: <snapshot> <target> <include> [dev|home]
restore snapshot target include profile="dev":
    resticprofile -n {{profile}} restore {{snapshot}} --include {{include}} --target {{target}}

# Restore latest home from B2: [target]
restore-from-b2 target="/tmp/home-restore":
    resticprofile -n b2-ops restore latest --tag home --target {{target}}

# --- Diff ---

# Diff latest two snapshots: [dev|home|...]
diff profile="dev":
    resticprofile -n {{profile}} diff latest~1 latest

# Diff two specific snapshots: <snap1> <snap2>
diff-snapshots snapshot1 snapshot2:
    resticprofile -n dev diff {{snapshot1}} {{snapshot2}}

# --- Notifications ---

# Test apprise notification: [success|fail|hc]
test-notify type="success":
    #!/usr/bin/env sh
    case "{{type}}" in
        success) apprise -c {{apprise}} --tag backup-success \
                   -t "Test: Backup Success" -b "Manual test $(date)" -vv ;;
        fail)    apprise -c {{apprise}} --tag backup-fail \
                   -t "Test: Backup FAILED" -b "Manual failure test" -vv ;;
        hc)      apprise -c {{apprise}} --tag hc-dev-backup-success \
                   -t "ping" -b "test" -vv ;;
        *)       echo "Unknown type: {{type}}. Use: success, fail, hc" && exit 1 ;;
    esac

# Rotate logs now (runs logrotate manually)
rotate-logs:
    mkdir -p "$HOME/.local/share/resticprofile/logs"
    logrotate --state "$HOME/.local/share/resticprofile/logrotate.state" \
              "$HOME/.config/resticprofile/logrotate.conf" -v

# --- Logs ---

# Tail profile log: [dev|home|copy|local|local-check|b2|b2-check]
log profile="dev":
    #!/usr/bin/env sh
    case "{{profile}}" in
        dev)         tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-dev.log" ;;
        home)        tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-home.log" ;;
        copy)        tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-local-to-b2.log" ;;
        local)       tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-local-ops-forget.log" ;;
        local-check) tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-local-ops-check.log" ;;
        b2)          tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-b2-ops-forget.log" ;;
        b2-check)    tail -f "$HOME/.local/share/resticprofile/logs/resticprofile-b2-ops-check.log" ;;
        *)     echo "Unknown profile: {{profile}}. Use: dev, home, copy, local, local-check, b2, b2-check" && exit 1 ;;
    esac
